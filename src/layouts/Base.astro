---
import '../styles/global.css';
import RevealScripts from '../components/RevealScripts.astro';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  jsonLd?: string[];
}

const {
  title,
  description,
  canonical = Astro.url.href,
  ogImage = '/brad-founder-sales-coach.jpg',
  jsonLd = [],
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<title>{title}</title>
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="description" content={description} />
<meta name="theme-color" content="#ffffff" />
<link rel="canonical" href={canonical} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content="website" />
<meta property="og:image" content={ogImage} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="robots" content="index,follow" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@1,400;1,500&display=swap" rel="stylesheet" />
{jsonLd.map((block) => (
  <script type="application/ld+json" set:html={block} />
))}
</head>
<body class="bg-white text-inkt">

<svg width="0" height="0" class="absolute" aria-hidden="true"><defs>
  <linearGradient id="g-ink" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="#3a3a3a"/><stop offset="1" stop-color="#0a0a0a"/></linearGradient>
</defs></svg>

<div class="p-3 sm:p-5">
  <slot />
</div>

<RevealScripts />

</body>
</html>
