---
import type { TeamMember } from '../lib/defaults';
interface Props { team: TeamMember[] }
const { team } = Astro.props;
---
<section id="coaches" class="reveal mt-3 sm:mt-5 rounded-4xl sm:rounded-5xl bg-ink text-white px-6 sm:px-12 py-14 sm:py-20">
  <div class="max-w-2xl">
    <span class="text-[12px] font-semibold tracking-[0.2em] uppercase text-gold">Our coaches</span>
    <h2 class="h-display text-3xl sm:text-5xl mt-3 text-white">Closers who carried <span class="accent">a quota</span></h2>
  </div>
  <div class="mt-10 sm:mt-14 grid grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6">
    {team.map((m) => (
      <div class="group">
        <div class="rounded-4xl overflow-hidden aspect-[3/4]">
          <img class="zoomimg w-full h-full object-cover" style={m.objectPosition ? `object-position:${m.objectPosition}` : undefined} src={m.imageUrl} alt={m.imageAlt} loading="lazy">
        </div>
        <div class="mt-3 font-medium">{m.name}</div>
        <div class="text-[13px] text-white/45">{m.role}</div>
      </div>
    ))}
  </div>
</section>
