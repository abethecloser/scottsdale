  <div class="mt-10 sm:mt-14 grid grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6">
    <div class="group"><div class="rounded-4xl overflow-hidden aspect-[3/4]"><img class="zoomimg w-full h-full object-cover" style="object-position:50% 22%" src="/brad-founder-sales-coach.jpg" width="500" height="667" alt="Brad, founder and head sales coach at Scottsdale Sales Training, Scottsdale AZ" loading="lazy"></div><div class="mt-3 font-medium">Brad</div><div class="text-[13px] text-white/45">Founder &amp; Head Coach</div></div>
