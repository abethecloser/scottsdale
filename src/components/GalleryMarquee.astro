---
import type { GalleryImage } from '../lib/defaults';
interface Props { gallery: GalleryImage[] }
const { gallery } = Astro.props;
const mid = Math.ceil(gallery.length / 2);
const row1 = gallery.slice(0, mid);
const row2 = gallery.slice(mid);
---
<section id="gallery" class="reveal mt-3 sm:mt-5 rounded-4xl sm:rounded-5xl bg-ink text-white py-12 sm:py-16">
  <div class="px-6 sm:px-12 mb-8 max-w-xl">
    <span class="text-[12px] font-semibold tracking-[0.2em] uppercase text-gold">Inside the room</span>
    <h2 class="h-display text-3xl sm:text-5xl mt-3 text-white">Real sessions, <span class="accent">real reps</span></h2>
  </div>
  <div class="mq-wrap mb-4">
    <div class="mq gap-4">
      <div class="flex gap-4 pr-4">
        {row1.map((g) => <img class="h-44 sm:h-56 w-auto rounded-4xl object-cover" src={g.imageUrl} alt={g.imageAlt}>)}
      </div>
      <div class="flex gap-4 pr-4" aria-hidden="true">
        {row1.map((g) => <img class="h-44 sm:h-56 w-auto rounded-4xl object-cover" src={g.imageUrl} alt="">)}
      </div>
    </div>
  </div>
  <div class="mq-wrap">
    <div class="mq rev gap-4">
      <div class="flex gap-4 pr-4">
        {row2.map((g) => <img class="h-44 sm:h-56 w-auto rounded-4xl object-cover" src={g.imageUrl} alt={g.imageAlt}>)}
      </div>
      <div class="flex gap-4 pr-4" aria-hidden="true">
        {row2.map((g) => <img class="h-44 sm:h-56 w-auto rounded-4xl object-cover" src={g.imageUrl} alt="">)}
      </div>
    </div>
  </div>
</section>
