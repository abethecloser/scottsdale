---
---
<main class="relative rounded-4xl sm:rounded-5xl overflow-hidden min-h-[82svh] flex">
  <img class="kenburns absolute inset-0 w-full h-full object-cover" src="https://images.unsplash.com/photo-1505373877841-8d25f7d46678?auto=format&fit=crop&w=1700&q=80" alt="Sales training workshop in session">
  <div class="absolute inset-0 bg-emerald-deep/35 mix-blend-multiply"></div>
  <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/25 to-black/75"></div>
  <div class="relative z-10 w-full flex flex-col justify-end items-center text-center px-6 pb-10 sm:pb-16">
    <p id="loc" class="mb-5 sm:mb-7 text-[11px] sm:text-[12px] font-medium tracking-[0.28em] uppercase text-white/65">
      <span class="word">Scottsdale,</span> <span class="word">Arizona</span>
    </p>
    <h1 id="headline" class="display hero-h text-white max-w-[16ch]">
      <span class="word">Close</span> <span class="word">More</span> <span class="word">Deals</span><br>
      <span class="word">On</span> <span class="word accent">Your</span> <span class="word">Terms</span>
    </h1>
    <p id="desc" class="mt-5 sm:mt-6 max-w-[440px] text-[15px] leading-relaxed text-white/90">
      Practical sales coaching that shortens your cycle and lifts win rates, built around the real deals your team is working right now.
    </p>
    <div id="cta-wrap" class="mt-8 sm:mt-10">
      <a href="#contact" class="pill-shadow-w inline-flex items-center gap-2 rounded-full bg-white text-inkt text-[15px] font-medium px-7 py-4 hover:bg-paper transition-colors">
        Book a Discovery Call
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
    </div>
  </div>
</main>
