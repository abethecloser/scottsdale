---
const path = Astro.url.pathname;
const isActive = (href: string) => (href === '/' ? path === '/' : path.startsWith(href));
const nav = [
  { label: 'About', href: '/about' },
  { label: 'Programs', href: '/programs' },
  { label: 'Insights', href: '/blog' },
  { label: 'FAQ', href: '/faq' },
];
---
<header class="flex items-center justify-between gap-4 px-2 sm:px-4 py-3 sm:py-4">
  <a href="/" class="flex items-center shrink-0"><img src="/fulllogo-wide.jpg" alt="Scottsdale Sales Training" class="h-9 sm:h-10 w-auto rounded-lg"></a>
  <nav class="hidden md:flex items-center gap-8 text-[14px] text-neutral-500">
    {nav.map((n) => (
      <a href={n.href} class={`hover:text-inkt transition-colors ${isActive(n.href) ? 'text-inkt font-medium' : ''}`}>{n.label}</a>
    ))}
  </nav>
  <a href="/contact" class="pill-shadow shrink-0 inline-flex items-center rounded-full bg-ink text-white text-[13px] sm:text-[14px] font-medium px-4 sm:px-5 py-2.5 hover:bg-char transition-colors">Request a quote</a>
</header>
