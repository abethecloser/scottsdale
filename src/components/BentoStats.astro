---
---
<section id="results" class="reveal mt-3 sm:mt-5">
  <div class="px-2 sm:px-4 mb-5 sm:mb-7 max-w-2xl">
    <span class="text-[12px] font-semibold tracking-[0.2em] uppercase text-emerald-light">Why teams win with us</span>
    <h2 class="h-display text-3xl sm:text-5xl mt-3">Proof you can <span class="accent">measure</span></h2>
  </div>
  <div class="grid grid-cols-2 md:grid-cols-4 auto-rows-[170px] md:auto-rows-[210px] gap-3 sm:gap-4">

    <!-- A: big image -->
    <a href="#gallery" class="group relative col-span-2 row-span-2 rounded-4xl overflow-hidden">
      <img class="zoomimg absolute inset-0 w-full h-full object-cover" src="https://images.unsplash.com/photo-1543269865-cbf427effbad?auto=format&fit=crop&w=1100&q=80" alt="Team workshop">
      <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/10 to-transparent"></div>
      <div class="absolute left-6 bottom-6 right-6 text-white">
        <div class="text-[12px] uppercase tracking-[0.18em] text-white/70">On-site &amp; virtual</div>
        <div class="text-2xl sm:text-3xl font-light mt-1">Workshops that rebuild how your team sells</div>
      </div>
    </a>

    <!-- B: emerald stat -->
    <div class="col-span-1 row-span-1 rounded-4xl bg-emerald text-white p-5 sm:p-6 flex flex-col justify-between">
      <div class="text-[12px] uppercase tracking-[0.16em] text-white/55">Win-rate</div>
      <div><div class="text-4xl sm:text-5xl font-light text-goldlt">38%</div><div class="text-[13px] text-white/65 mt-1">average lift</div></div>
    </div>

    <!-- C: gold flat stat -->
    <div class="col-span-1 row-span-1 rounded-4xl bg-gold text-inkt p-5 sm:p-6 flex flex-col justify-between">
      <div class="text-[12px] uppercase tracking-[0.16em] text-inkt/60">Trained</div>
      <div><div class="text-4xl sm:text-5xl font-light">2,500+</div><div class="text-[13px] text-inkt/70 mt-1">reps since 2009</div></div>
    </div>

    <!-- D: video-style tile -->
    <button data-video class="group col-span-2 row-span-1 relative rounded-4xl overflow-hidden text-left">
      <img class="zoomimg absolute inset-0 w-full h-full object-cover" src="https://images.unsplash.com/photo-1475721027785-f74eccf877e2?auto=format&fit=crop&w=1100&q=80" alt="Keynote">
      <div class="absolute inset-0 bg-black/45"></div>
      <div class="absolute inset-0 flex items-center gap-4 px-6">
        <span class="w-14 h-14 rounded-full bg-white/95 text-ink flex items-center justify-center shrink-0 group-hover:scale-105 transition"><svg class="w-5 h-5 ml-0.5" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg></span>
        <span class="text-white"><span class="block text-[12px] uppercase tracking-[0.16em] text-white/70">Watch · 0:48</span><span class="block text-lg sm:text-xl font-light mt-0.5">Inside a live workshop</span></span>
      </div>
    </button>

    <!-- E: small image -->
    <a href="#coaches" class="group col-span-1 row-span-1 relative rounded-4xl overflow-hidden">
      <img class="zoomimg absolute inset-0 w-full h-full object-cover" src="https://images.unsplash.com/photo-1521737711867-e3b97375f902?auto=format&fit=crop&w=600&q=80" alt="1-on-1 coaching">
      <div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent"></div>
      <div class="absolute left-4 bottom-4 text-white text-[14px] font-medium">1-on-1 coaching</div>
    </a>

    <!-- F: quote -->
    <div class="col-span-2 row-span-1 rounded-4xl bg-ink text-white p-6 flex flex-col justify-center">
      <div class="flex gap-1 text-gold mb-2"><svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="m12 2 2.9 6.3L22 9.3l-5 4.7 1.3 6.9L12 17.6 5.7 20.9 7 14 2 9.3l7.1-1z"/></svg><svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="m12 2 2.9 6.3L22 9.3l-5 4.7 1.3 6.9L12 17.6 5.7 20.9 7 14 2 9.3l7.1-1z"/></svg><svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="m12 2 2.9 6.3L22 9.3l-5 4.7 1.3 6.9L12 17.6 5.7 20.9 7 14 2 9.3l7.1-1z"/></svg><svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="m12 2 2.9 6.3L22 9.3l-5 4.7 1.3 6.9L12 17.6 5.7 20.9 7 14 2 9.3l7.1-1z"/></svg><svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="m12 2 2.9 6.3L22 9.3l-5 4.7 1.3 6.9L12 17.6 5.7 20.9 7 14 2 9.3l7.1-1z"/></svg></div>
      <p class="text-[15px] sm:text-base leading-snug">"Close rate up 30% in a quarter."</p>
      <div class="text-[12px] text-white/50 mt-2">Marcus Delgado, VP Sales</div>
    </div>

    <!-- G: gold-outline stat -->
    <div class="col-span-1 row-span-1 rounded-4xl bg-paper ring-gold p-5 sm:p-6 flex flex-col justify-between">
      <div class="text-[12px] uppercase tracking-[0.16em] text-inkt/45">Ramp</div>
      <div><div class="text-4xl sm:text-5xl font-light text-emerald-light">8 wks</div><div class="text-[13px] text-inkt/55 mt-1">new-hire to quota</div></div>
    </div>
  </div>
</section>
