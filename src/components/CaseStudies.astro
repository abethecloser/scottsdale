---
import type { CaseStudy } from '../lib/defaults';
interface Props { caseStudies: CaseStudy[] }
const { caseStudies } = Astro.props;
---
<section id="cases" class="reveal mt-3 sm:mt-5 rounded-4xl sm:rounded-5xl bg-paper px-6 sm:px-12 py-14 sm:py-20">
  <div class="max-w-2xl mb-10"><span class="text-[12px] font-semibold tracking-[0.2em] uppercase text-emerald-light">Case studies</span><h2 class="h-display text-3xl sm:text-5xl mt-3">Engagements that moved <span class="accent">the number</span></h2></div>
  <div class="grid lg:grid-cols-3 gap-4 sm:gap-5">
    {caseStudies.map((c) => (
      <article class="rounded-4xl overflow-hidden bg-white ring-1 ring-inkt/8">
        <div class="h-44 overflow-hidden"><img class="w-full h-full object-cover" src={c.imageUrl} alt={c.imageAlt}></div>
        <div class="p-6"><div class="text-[12px] uppercase tracking-[0.16em] text-emerald-light">{c.category}</div><div class="text-3xl font-light text-emerald-light mt-2">{c.headlineStat}</div><p class="mt-3 text-[14px] text-inkt/60">{c.description}</p></div>
      </article>
    ))}
  </div>
</section>
