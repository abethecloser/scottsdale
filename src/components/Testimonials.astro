---
import type { Testimonial } from '../lib/defaults';
interface Props { testimonials: Testimonial[] }
const { testimonials } = Astro.props;
const clamp = (n: number) => Math.min(5, Math.max(0, n ?? 5));
---
<section class="reveal mt-3 sm:mt-5 rounded-4xl sm:rounded-5xl bg-paper2 px-6 sm:px-12 py-14 sm:py-20" data-carousel data-auto>
  <div class="max-w-xl mb-8 sm:mb-12">
    <span class="text-[12px] font-semibold tracking-[0.2em] uppercase text-emerald-light">What clients say</span>
    <h2 class="h-display text-3xl sm:text-5xl mt-3">Teams that <span class="accent">win more</span></h2>
  </div>
  <div class="car" data-track>
    {testimonials.map((t) => (
      <figure class="car-card rounded-4xl bg-white ring-1 ring-inkt/8 p-7 flex flex-col">
        <div class="flex gap-1 text-gold mb-4">
          {Array.from({ length: clamp(t.rating) }).map(() => (
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="m12 2 2.9 6.3L22 9.3l-5 4.7 1.3 6.9L12 17.6 5.7 20.9 7 14 2 9.3l7.1-1z"/></svg>
          ))}
        </div>
        <blockquote class="text-[15px] leading-relaxed text-inkt/85 flex-1">{t.quote}</blockquote>
        <figcaption class="mt-5 flex items-center gap-3">
          {t.imageUrl && <img class="w-10 h-10 rounded-full object-cover" src={t.imageUrl} alt="">}
          <span><span class="block text-[14px] font-medium">{t.name}</span><span class="block text-[12px] text-inkt/50">{t.titleCompany}</span></span>
        </figcaption>
      </figure>
    ))}
  </div>
  <div data-dots class="flex gap-2 mt-8"></div>
</section>
