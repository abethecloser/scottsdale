---
<section id="contact" class="reveal mt-3 sm:mt-5 rounded-4xl sm:rounded-5xl bg-ink text-white px-6 sm:px-12 py-14 sm:py-20">
  <div class="grid lg:grid-cols-2 gap-10 lg:gap-16">
    <div>
      <span class="text-[12px] font-semibold tracking-[0.2em] uppercase text-gold">Get in touch</span>
      <h2 class="h-display text-3xl sm:text-5xl mt-3 text-white">Tell us about <span class="accent">your team</span></h2>
      <p class="mt-5 text-[15px] text-white/65 max-w-md">We'll come back within one business day with a plan, or book a free 20-minute call now.</p>
      <a href="tel:+14805551234" class="mt-7 inline-flex items-center gap-2 text-[16px] font-medium text-gold hover:text-goldlt"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M6.6 10.8a15 15 0 0 0 6.6 6.6l2.2-2.2a1 1 0 0 1 1-.25 11.4 11.4 0 0 0 3.6.57 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.25.2 2.46.57 3.6a1 1 0 0 1-.25 1l-2.2 2.2z"/></svg>(480) 555-1234</a>
    </div>
    <form id="leadform" action="/api/lead" method="post" class="space-y-4">
      <input type="text" name="company_website" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true">
      <div class="grid sm:grid-cols-2 gap-4">
        <label class="block"><span class="text-[13px] text-white/55">Name</span><input required name="name" class="mt-1.5 w-full bg-white/[.06] border border-white/15 rounded-xl px-4 py-3 text-[15px] placeholder-white/30 focus:border-gold focus:outline-none" placeholder="Your name"></label>
        <label class="block"><span class="text-[13px] text-white/55">Company</span><input name="company" class="mt-1.5 w-full bg-white/[.06] border border-white/15 rounded-xl px-4 py-3 text-[15px] placeholder-white/30 focus:border-gold focus:outline-none" placeholder="Company"></label>
      </div>
      <div class="grid sm:grid-cols-2 gap-4">
        <label class="block"><span class="text-[13px] text-white/55">Email</span><input required type="email" name="email" class="mt-1.5 w-full bg-white/[.06] border border-white/15 rounded-xl px-4 py-3 text-[15px] placeholder-white/30 focus:border-gold focus:outline-none" placeholder="you@company.com"></label>
        <label class="block"><span class="text-[13px] text-white/55">Team size</span><input name="team" class="mt-1.5 w-full bg-white/[.06] border border-white/15 rounded-xl px-4 py-3 text-[15px] placeholder-white/30 focus:border-gold focus:outline-none" placeholder="e.g. 8 reps"></label>
      </div>
      <label class="block"><span class="text-[13px] text-white/55">What do you want to improve?</span><textarea name="message" rows="3" class="mt-1.5 w-full bg-white/[.06] border border-white/15 rounded-xl px-4 py-3 text-[15px] placeholder-white/30 focus:border-gold focus:outline-none" placeholder="Objection handling, ramp time, closing..."></textarea></label>
      <button type="submit" class="w-full bg-gold text-ink font-semibold text-[14px] rounded-xl px-6 py-4 hover:bg-goldlt transition">Request my plan</button>
      <p id="formmsg" class="text-[14px] text-gold hidden">Thanks! We'll be in touch within one business day.</p>
    </form>
  </div>
</section>
<script is:inline>(function(){var f=document.getElementById('leadform');if(!f)return;f.addEventListener('submit',function(e){e.preventDefault();if(f.company_website.value)return;var btn=f.querySelector('button[type=submit]');var data=new FormData(f);fetch('/api/lead',{method:'POST',body:data}).then(function(r){return r.json().catch(function(){return{ok:r.ok};});}).then(function(){document.getElementById('formmsg').classList.remove('hidden');f.reset();}).catch(function(){document.getElementById('formmsg').classList.remove('hidden');f.reset();});});})();</script>
