---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CtaBand from '../../components/CtaBand.astro';
import { getPublishedPosts, getSiteSettings } from '../../lib/queries';

const [posts, settings] = await Promise.all([getPublishedPosts(), getSiteSettings()]);

const fmt = (d: string) =>
  d ? new Date(d).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) : '';
---
<Base
  title="Insights & Sales Playbook | Scottsdale Sales Training"
  description="Practical sales articles on objection handling, discovery, ramp, and closing from Scottsdale Sales Training."
>
  <Header />

  <section class="reveal relative rounded-4xl sm:rounded-5xl overflow-hidden mt-2 bg-ink text-white px-6 sm:px-12 py-16 sm:py-24">
    <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(600px 320px at 20% 0%,rgba(35,165,121,.18),transparent 60%)"></div>
    <div class="relative max-w-2xl">
      <span class="text-[12px] font-semibold tracking-[0.2em] uppercase text-gold">Insights</span>
      <h1 class="h-display text-4xl sm:text-6xl mt-3 text-white">From the <span class="accent">playbook</span></h1>
      <p class="mt-5 text-[15px] text-white/70 max-w-lg">Practical notes on objection handling, discovery, ramp, and closing, from the coaches at Scottsdale Sales Training.</p>
    </div>
  </section>

  {posts.length ? (
    <section class="reveal mt-3 sm:mt-5">
      <div class="grid md:grid-cols-3 gap-4 sm:gap-5">
        {posts.map((post) => (
          <a href={`/blog/${post.slug}`} class="group rounded-4xl overflow-hidden bg-white ring-1 ring-inkt/8">
            <div class="h-52 overflow-hidden"><img class="zoomimg w-full h-full object-cover" src={post.coverImageUrl} alt={post.coverImageAlt}></div>
            <div class="p-6">
              <div class="flex items-center gap-3 text-[12px] text-inkt/45">
                <span class="text-emerald-light font-medium">{post.category}</span>
                <span>{fmt(post.publishedAt)}</span>
              </div>
              <h2 class="text-lg font-medium mt-2">{post.title}</h2>
              <p class="mt-2 text-[14px] text-inkt/55">{post.excerpt}</p>
            </div>
          </a>
        ))}
      </div>
    </section>
  ) : (
    <section class="reveal mt-3 sm:mt-5 rounded-4xl sm:rounded-5xl bg-paper px-6 sm:px-12 py-20 text-center">
      <h2 class="h-display text-2xl sm:text-3xl">New articles coming soon</h2>
      <p class="mt-3 text-[15px] text-inkt/55">We're writing up our best sales playbooks. Check back shortly.</p>
    </section>
  )}

  <div class="mt-3 sm:mt-5"><CtaBand settings={settings} /></div>
  <Footer settings={settings} />
</Base>
